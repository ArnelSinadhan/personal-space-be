# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_space

# ── Firebase ──────────────────────────────────────
# Paste the entire service account JSON as a single line, OR use the path variant:
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Security ──────────────────────────────────────
VAULT_ENCRYPTION_SECRET=change-me-to-a-random-32-byte-hex-string
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
VAULT_SESSION_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://personal-space.vercel.app

# ── Firebase Storage ──────────────────────────────
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ── Environment ───────────────────────────────────
ENVIRONMENT=development
DEBUG=true
