# local
APP_PORT_LOCAL=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_space
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VAULT_ENCRYPTION_SECRET=change-me-to-a-random-32-byte-hex-string
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
VAULT_SESSION_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=development
DEBUG=true
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROFILE_IMAGES_BUCKET=profile-images
SUPABASE_COMPANY_IMAGES_BUCKET=company-images
SUPABASE_CERTIFICATION_IMAGES_BUCKET=certification-images
SUPABASE_PROJECT_IMAGES_BUCKET=project-images
SUPABASE_RESUME_FILES_BUCKET=resume-files
SIGNED_URL_EXPIRE_SECONDS=3600
PUBLIC_TESTIMONIAL_CAPTCHA_SECRET=your-turnstile-secret
PUBLIC_TESTIMONIAL_CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
PUBLIC_TESTIMONIAL_RATE_LIMIT_WINDOW_MINUTES=60
PUBLIC_TESTIMONIAL_RATE_LIMIT_MAX_ATTEMPTS=3

# production
# PORT is provided by Railway in production. Keep 8000 only as a fallback/default.
# PORT=8000
# DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?ssl=require
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VAULT_ENCRYPTION_SECRET=replace-with-a-real-production-secret
# JWT_SECRET=replace-with-a-real-production-secret
# JWT_ALGORITHM=HS256
# VAULT_SESSION_EXPIRE_MINUTES=30
# ALLOWED_ORIGINS=https://your-frontend-domain.com
# ENVIRONMENT=production
# DEBUG=false
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
# SUPABASE_PROFILE_IMAGES_BUCKET=profile-images
# SUPABASE_COMPANY_IMAGES_BUCKET=company-images
# SUPABASE_CERTIFICATION_IMAGES_BUCKET=certification-images
# SUPABASE_PROJECT_IMAGES_BUCKET=project-images
# SUPABASE_RESUME_FILES_BUCKET=resume-files
# SIGNED_URL_EXPIRE_SECONDS=3600
# PUBLIC_TESTIMONIAL_CAPTCHA_SECRET=your-turnstile-secret
# PUBLIC_TESTIMONIAL_CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
# PUBLIC_TESTIMONIAL_RATE_LIMIT_WINDOW_MINUTES=60
# PUBLIC_TESTIMONIAL_RATE_LIMIT_MAX_ATTEMPTS=3
